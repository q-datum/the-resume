# Use official Gradle image with JDK 17
FROM gradle:8.5-jdk17 AS dev
WORKDIR /app

# Copy only Gradle files first (for caching dependencies)
COPY build.gradle settings.gradle gradlew* ./
COPY gradle ./gradle
RUN gradle build --no-daemon -x test || return 0

# Copy source code
COPY . .

# Expose backend port
EXPOSE 8080

# Run Spring Boot in dev mode
CMD ["gradle", "bootRun"]
